{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm turbo build --filter=@human-os/renubu",
  "crons": [
    {
      "path": "/api/cron/evaluate-tasks",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/cleanup-expired-tenants",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/demo/reset",
      "schedule": "0 7 * * *"
    }
  ]
}
